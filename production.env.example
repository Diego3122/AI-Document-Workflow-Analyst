# Azure / production defaults
ENVIRONMENT=production
AUTH_MODE=jwt
ENABLE_API_DOCS=false
UI_PUBLIC_ENABLED=true
UI_API_BASE_URL=http://127.0.0.1:8000
WEBSITES_PORT=8501
WEBSITES_ENABLE_APP_SERVICE_STORAGE=true

# Azure App Service identity forwarding
UI_FORWARDED_ACCESS_TOKEN_HEADERS=X-Ms-Token-Aad-Access-Token,Authorization
TRUST_PROXY_HEADERS=true
PROXY_TRUSTED_IPS=*
TRUSTED_HOSTS=<your-app-name>.azurewebsites.net,127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://<your-app-name>.azurewebsites.net

# Microsoft Entra JWT validation
JWT_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
JWT_AUDIENCES=api://<your-api-app-id-or-client-id>
JWT_ALGORITHMS=RS256
JWT_REQUIRE_HTTPS_METADATA=true
JWT_JWKS_URL=
JWT_SHARED_SECRET=
JWT_DEFAULT_ROLE=analyst
JWT_ADMIN_SUBJECTS=
JWT_ADMIN_EMAILS=you@yourtenant.com

# Persistent Azure storage
UPLOADS_DIR=/home/site/data/uploads
CHROMA_DIR=/home/site/data/chroma
LOGS_DIR=/home/site/data/logs
EVALS_DIR=/home/site/data/evals
SQLITE_PATH=/home/site/data/logs/app.db
DOCUMENT_RETENTION_DAYS=30

# Provider selection and safe deployment guardrails
GEMINI_API_KEY=<set-in-app-settings-or-key-vault>
OPENAI_API_KEY=
LLM_PROVIDER=auto
EMBEDDING_PROVIDER=auto
PROVIDER_RATE_LIMIT_WINDOW_SECONDS=60
PROVIDER_MAX_REQUESTS_PER_WINDOW=10
PROVIDER_DAILY_REQUEST_LIMIT=50
PROVIDER_DAILY_INPUT_CHAR_LIMIT=100000
PROVIDER_PER_USER_MAX_REQUESTS_PER_WINDOW=5
PROVIDER_PER_USER_DAILY_REQUEST_LIMIT=25
PROVIDER_PER_USER_DAILY_INPUT_CHAR_LIMIT=50000
PROVIDER_DAILY_ESTIMATED_COST_LIMIT_USD=
PROVIDER_PER_USER_DAILY_ESTIMATED_COST_LIMIT_USD=
LLM_ESTIMATED_COST_PER_1K_CHARS_USD=0.00
EMBEDDING_ESTIMATED_COST_PER_1K_CHARS_USD=0.00
